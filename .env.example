# =============================================================================
# World Monitor — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# Keys marked [optional] degrade gracefully — the app still runs without them.
# =============================================================================

# ── Reverse Proxy ─────────────────────────────────────────────────────────────
# Domain served by Caddy (e.g. worldmonitor.yourdomain.duckdns.org)
WM_DOMAIN=worldmonitor.localhost

# ── Internal Auth ─────────────────────────────────────────────────────────────
# Shared token between worldmonitor app and redis-rest proxy.
# Change this to a random string in production.
REDIS_TOKEN=wm-local-token

# ── LLM — pick one or both [optional] ────────────────────────────────────────
# Used for intelligence assessments / AI summaries
GROQ_API_KEY=             # https://console.groq.com  (free, 14.4K req/day)
OPENROUTER_API_KEY=       # https://openrouter.ai     (free, 50 req/day)

# Self-hosted LLM (any OpenAI-compatible endpoint) [optional]
LLM_API_URL=              # e.g. http://192.168.1.x:11434/v1/chat/completions
LLM_API_KEY=
LLM_MODEL=                # e.g. llama3, mistral, gemma3

# ── Markets & Economics [optional] ───────────────────────────────────────────
FINNHUB_API_KEY=          # https://finnhub.io              (free tier)
FRED_API_KEY=             # https://fred.stlouisfed.org     (free)
EIA_API_KEY=              # https://www.eia.gov/opendata/   (free)

# ── Conflict & Unrest [optional] ─────────────────────────────────────────────
ACLED_ACCESS_TOKEN=       # https://acleddata.com           (free for researchers)

# ── Earth Observation [optional] ─────────────────────────────────────────────
NASA_FIRMS_API_KEY=       # https://firms.modaps.eosdis.nasa.gov (free)

# ── Aviation [optional] ──────────────────────────────────────────────────────
AVIATIONSTACK_API=        # https://aviationstack.com       (free tier)

# ── Maritime [optional] ──────────────────────────────────────────────────────
# Required by BOTH worldmonitor and ais-relay services
AISSTREAM_API_KEY=        # https://aisstream.io            (free)

# ── Internet Outages [paid] ───────────────────────────────────────────────────
CLOUDFLARE_API_TOKEN=     # https://dash.cloudflare.com    (requires Radar access)
